---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Edwin — Home">
  <section class="hero">
    <div class="hero-content">
      <div class="availability-badge">
        <span class="availability-dot"></span>
        Open to New Projects and Collaborations
      </div>
      <h1>Edwin Tieu</h1>
      <p class="hero-subtitle">
        Embedded Software Engineer building resilient defense systems - <br />
        from Inertial Navigation Systems to Acoustic Localization Networks.
      </p>
      <div class="hero-links">
        <a href="https://github.com/EdwinTieu5642" class="hero-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.69-3.87-1.36-3.87-1.36-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5Z" />
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/edwin-tieu-2abbd/" class="hero-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.56c0-1.33-.03-3.04-1.86-3.04-1.86 0-2.15 1.45-2.15 2.95v5.65H9.34V9h3.4v1.56h.05c.47-.9 1.63-1.86 3.35-1.86 3.59 0 4.25 2.36 4.25 5.43v6.32ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.46C23.21 24 24 23.23 24 22.27V1.73C24 .77 23.21 0 22.23 0Z" />
          </svg>
        </a>
        <a href="mailto:edwindysontieu@gmail.com" class="hero-link" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m2 7 10 6 10-6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="about" id="about">
    <h2 class="about-title">About Me</h2>
    <div class="intro">
      <img src="/edwin.jpg" alt="Edwin Tieu" class="intro-photo" />
      <div class="intro-text">
        <p>
          I'm an Embedded Software Engineer passionate about solving hard problems at the intersection of AI and Defense. I earned both my B.S. in Computer Science and Computer Engineering and my M.S. in Computer Engineering from USC.
        </p>
        <p>
          I'm driven by building systems that have real-world impact, especially technologies that can help protect and save lives. My goal is to continuously grow by taking on challenging problems and pushing myself to learn as quickly as possible.
        </p>
        <p>
          In my free time, I like to work on developing iOS Applications, learn more about Machine Learning and Artificial Intelligence systems, and ideate new and exciting projects to work on next.
        </p>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-value">1</span>
        <span class="stat-label">iOS App Shipped</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">3</span>
        <span class="stat-label">Research Projects</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">3</span>
        <span class="stat-label">Internships Worked</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">∞</span>
        <span class="stat-label">Curiosity</span>
      </div>
    </div>
  </section>

  <section class="find-me">
    <h2>Find Me</h2>
    <ul>
      <li><a href="https://github.com/EdwinTieu5642" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      <li><a href="mailto:edwindysontieu@gmail.com">Email</a></li>
    </ul>
  </section>
</BaseLayout>
